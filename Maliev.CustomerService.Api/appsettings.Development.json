{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "CustomerDbContext": ""
  },
  "Jwt": {
    "Authority": "",
    "Audience": ""
  },
  "ExternalServices": {
    "UploadService": {
      "BaseUrl": "",
      "TimeoutSeconds": 300,
      "RetryCount": 3,
      "EnableCircuitBreaker": true,
      "MaxFileSizeMB": 50
    },
    "CountryService": {
      "BaseUrl": "",
      "TimeoutSeconds": 30,
      "RetryCount": 3,
      "EnableCircuitBreaker": true,
      "CacheDurationHours": 24
    }
  }
}