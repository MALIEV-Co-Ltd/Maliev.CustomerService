{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "CustomerDbContext": "${ConnectionStrings__CustomerDbContext}"
  },
  "Jwt": {
    "Authority": "${Jwt__Authority}",
    "Audience": "${Jwt__Audience}"
  },
  "ExternalServices": {
    "UploadService": {
      "BaseUrl": "${ExternalServices__UploadService__BaseUrl}",
      "TimeoutSeconds": 300,
      "RetryCount": 3,
      "EnableCircuitBreaker": true,
      "MaxFileSizeMB": 50
    },
    "CountryService": {
      "BaseUrl": "${ExternalServices__CountryService__BaseUrl}",
      "TimeoutSeconds": 30,
      "RetryCount": 3,
      "EnableCircuitBreaker": true,
      "CacheDurationHours": 24
    }
  }
}
