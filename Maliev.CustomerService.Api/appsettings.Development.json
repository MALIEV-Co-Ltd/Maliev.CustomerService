{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "CustomerDbContext": "Host=localhost;Port=5432;Database=customer_app_db;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Authority": "",
    "Audience": ""
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "Enabled": false
  },
  "RabbitMQ": {
    "Enabled": false
  },
  "ExternalServices": {
    "UploadService": {
      "BaseUrl": "",
      "TimeoutInSeconds": 180,
      "RetryCount": 3,
      "EnableCircuitBreaker": true,
      "MaxFileSizeMB": 50
    },
    "CountryService": {
      "BaseUrl": "",
      "TimeoutInSeconds": 180,
      "RetryCount": 3,
      "EnableCircuitBreaker": true,
      "CacheDurationHours": 24
    }
  }
}